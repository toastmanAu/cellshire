# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Node — only present if a contributor adds tooling later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment and deployment secrets
.env
.env.*
!.env.example
bank-testnet-values.json
bank-*-values.json
*-smoke-report.json
bank-backend-readiness-report.json
cellshire.bank.*.report

# Build output (generated by netlify-build.mjs on every deploy)
dist/

# Netlify CLI local state — links a checkout to a particular Netlify
# project, so it's per-developer and must NOT be committed.
.netlify/

# Wrangler local cache/state for Cloudflare Pages deploys.
.wrangler/

# Webp duplicates of the .png assets in assets/newAsset/ — the runtime
# only loads the .png variants; the .webp files are unreferenced
# byproducts of the asset-export pipeline.
assets/newAsset/*.webp

# Asset-gen workspace — temporary cuts before installation
cs_logo.png
assets/raw_pending/
assets/raw_mining_originals/
assets/assets_cellshire.zip
tmp/
scripts/_sa3_stubs/

# Python tooling cache
__pycache__/
*.py[cod]
